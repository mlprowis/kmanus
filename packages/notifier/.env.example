# GRVT Grid Notifier — environment
#
# Database (read-only). Point at the live bot's SQLite file.
GRID_BOT_DB=/opt/grvt-grid-bot/data/grid_bot.db

# Telegram credentials. Get the bot token from @BotFather, then send any
# message to your bot and grab your chat_id from
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Tunables
NOTIFIER_POLL_MS=10000              # how often to check for new events
NOTIFY_DRAWDOWN_PCT=15              # alert when drawdown from HWM > this %
NOTIFY_FILL_BATCH=5                 # batch fills into one message
DAILY_SUMMARY_HOUR_UTC=0            # 0..23, 24 to disable

# State directory (where the cursor JSON lives)
NOTIFIER_STATE_DIR=/var/lib/grvt-grid-notifier

# Log level (debug | info | warn | error)
LOG_LEVEL=info
